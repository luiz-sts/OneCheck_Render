FROM php:8.2-apache

RUN apt-get update && apt-get install -y --no-install-recommends \
    libcurl4-openssl-dev \
    && docker-php-ext-install curl \
    && a2enmod rewrite headers \
    && rm -rf /var/lib/apt/lists/*

COPY docker/apache.conf /etc/apache2/sites-available/000-default.conf
COPY docker/start-web.sh /usr/local/bin/start-web.sh
RUN chmod +x /usr/local/bin/start-web.sh

WORKDIR /var/www/html
COPY . /var/www/html/

RUN chown -R www-data:www-data /var/www/html

# Variáveis de ambiente com defaults seguros
ENV ONECHECK_BASE_PATH=""
ENV ONECHECK_API_URL="http://3.145.6.22:8000"
ENV ONECHECK_JWT_SECRET=""

EXPOSE 80
CMD ["/usr/local/bin/start-web.sh"]
